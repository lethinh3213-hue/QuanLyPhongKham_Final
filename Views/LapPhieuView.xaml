<Window x:Class="QuanLyPhongKham.Views.LapPhieuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lập phiếu khám bệnh"
        Height="600" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="BlueButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ReadOnlyBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="20,15">
                <Grid>
                    <TextBlock Text="Lập phiếu khám bệnh" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="16"
                            Foreground="#6B7280"
                            Cursor="Hand"
                            Command="{Binding ThoatCommand}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HÀNG 1 -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Mã phiếu khám bệnh" Style="{StaticResource LabelStyle}"/>
                        <TextBox Style="{StaticResource ReadOnlyBox}" Text="{Binding MaPhieuKhamBenh}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,5,0">
                        <TextBlock Text="Ngày khám" Style="{StaticResource LabelStyle}"/>
                        <DatePicker SelectedDate="{Binding NgayKham}" Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5,0,5,0">
                        <TextBlock Text="Tên loại phòng khám" Style="{StaticResource LabelStyle}"/>
                        <ComboBox Height="36"
                                  ItemsSource="{Binding DanhSachLoaiPhongKham}"
                                  SelectedItem="{Binding LoaiPhongKhamDuocChon}"
                                  DisplayMemberPath="TenLoaiPhongKham"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="10,0,0,0">
                        <TextBlock Text="Họ tên bệnh nhân" Style="{StaticResource LabelStyle}"/>
                        <ComboBox Height="36"
                                  ItemsSource="{Binding DanhSachBenhNhan}"
                                  SelectedItem="{Binding BenhNhanDuocChon}"
                                  DisplayMemberPath="HoTen"/>
                    </StackPanel>
                </Grid>

                <!-- HÀNG 2 -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Triệu chứng" Style="{StaticResource LabelStyle}"/>
                        <TextBox Height="36" Text="{Binding TrieuChung}" Padding="8,0" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,5,0">
                        <TextBlock Text="Tên loại bệnh dự đoán" Style="{StaticResource LabelStyle}"/>
                        <ComboBox Height="36"
                                  ItemsSource="{Binding DanhSachLoaiBenh}"
                                  SelectedItem="{Binding LoaiBenhDuocChon}"
                                  DisplayMemberPath="TenLoaiBenh"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5,0,5,0">
                        <TextBlock Text="Ghi chú" Style="{StaticResource LabelStyle}"/>
                        <TextBox Height="36" Text="{Binding GhiChu}" Padding="8,0" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="10,0,0,0">
                        <TextBlock Text="Tổng số lượng thuốc kê" Style="{StaticResource LabelStyle}"/>
                        <TextBox Style="{StaticResource ReadOnlyBox}" Text="{Binding TongSoLuongThuoc}"/>
                    </StackPanel>
                </Grid>

                <!-- DATAGRID: bỏ CanUserAddRows -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding DanhSachThuocKe}"
                          SelectedItem="{Binding ThuocKeDuocChon}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="True"
                          BorderBrush="#D1D5DB"
                          BorderThickness="1"
                          GridLinesVisibility="All"
                          RowHeaderWidth="0"
                          Margin="0,0,0,15">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60" IsReadOnly="True"/>

                        <DataGridTemplateColumn Header="Tên thuốc" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.DanhSachLoaiThuoc, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding ThuocChon, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="TenLoaiThuoc"
                                              BorderThickness="0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Đơn vị" Binding="{Binding TenDonVi}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Số lượng còn lại" Binding="{Binding SoLuongConLai}" Width="130" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Số lượng kê" Binding="{Binding SoLuongKe, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <DataGridTextColumn Header="Cách dùng" Binding="{Binding TenCachDung}" Width="150" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="3" Margin="0,10,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Lập phiếu khám bệnh"
                        Style="{StaticResource BlueButton}"
                        Command="{Binding LuuPhieuCommand}"
                        MinWidth="160"
                        Margin="0,0,15,0"/>
                    <Button Grid.Column="1" Content="Tra cứu bệnh nhân"
                        Style="{StaticResource BlueButton}"
                        Command="{Binding TraCuuCommand}"
                        MinWidth="160"/>
                    <Button Grid.Column="3" Content="Thoát"
                        Style="{StaticResource BlueButton}"
                        Command="{Binding ThoatCommand}"
                        MinWidth="100"
                        Margin="0,0,5,0"/>  
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
