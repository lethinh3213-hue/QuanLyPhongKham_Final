<Window x:Class="QuanLyPhongKham.Views.TiepNhanView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Tiếp nhận danh sách khám bệnh"
        Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Danh sách Giới tính dùng cho ComboBox trong DataGrid -->
        <x:Array x:Key="DanhSachGioiTinh" Type="sys:String">
            <sys:String>Nam</sys:String>
            <sys:String>Nữ</sys:String>
        </x:Array>

        <Style x:Key="BlueButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" 
                    BorderBrush="#E5E7EB" 
                    BorderThickness="0,0,0,1"
                    Padding="20,15">
                <Grid>
                    <TextBlock Text="Tiếp nhận danh sách khám bệnh"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="16"
                            Foreground="#6B7280"
                            Cursor="Hand"
                            Command="{Binding ThoatCommand}"/>
                </Grid>
            </Border>

            <!-- NỘI DUNG -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 3 TRƯỜNG NHẬP -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Ngày khám" Foreground="#374151" Margin="0,0,0,6"/>
                        <DatePicker SelectedDate="{Binding NgayKham}" Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,5,0">
                        <TextBlock Text="Mã loại phòng khám" Foreground="#374151" Margin="0,0,0,6"/>
                        <TextBox Height="36"
                                 Text="{Binding MaLoaiPhongKham}"
                                 IsReadOnly="True"
                                 Background="#F9FAFB"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                        <TextBlock Text="Tên phòng khám" Foreground="#374151" Margin="0,0,0,6"/>
                        <ComboBox Height="36"
                                  ItemsSource="{Binding DanhSachLoaiPhongKham}"
                                  SelectedItem="{Binding LoaiPhongKhamDuocChon}"
                                  DisplayMemberPath="TenLoaiPhongKham"/>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="Danh sách khám bệnh"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                <!-- DATAGRID -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding DanhSachBenhNhan}"
                          SelectedItem="{Binding BenhNhanDuocChon}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          BorderBrush="#D1D5DB"
                          BorderThickness="1"
                          GridLinesVisibility="All"
                          Margin="0,0,0,20"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Họ tên" Binding="{Binding HoTen}" Width="*"/>

                        <!-- Giới tính: ComboBox Nam/Nữ -->
                        <DataGridComboBoxColumn Header="Giới tính"
                                                ItemsSource="{StaticResource DanhSachGioiTinh}"
                                                SelectedItemBinding="{Binding GioiTinh}"
                                                Width="120"/>

                        <DataGridTextColumn Header="Năm sinh" Binding="{Binding NamSinh}" Width="120"/>

                        <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 6 NÚT BẤM -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Tiếp nhận danh sách"
                            Style="{StaticResource BlueButton}"
                            Command="{Binding TiepNhanCommand}" Margin="0,0,5,0"/>
                    <Button Grid.Column="1" Content="Thêm bệnh nhân"
                            Style="{StaticResource BlueButton}"
                            Command="{Binding ThemBenhNhanCommand}" Margin="5,0,5,0"/>
                    <Button Grid.Column="2" Content="Tìm kiếm "
                            Style="{StaticResource BlueButton}"
                            Command="{Binding TimKiemCommand}" Margin="5,0,5,0"/>
                    <Button Grid.Column="3" Content="Xóa bệnh nhân"
                            Style="{StaticResource BlueButton}"
                            Command="{Binding XoaCommand}" Margin="5,0,5,0"/>
                    <Button Grid.Column="4" Content="Cập nhật"
                            Style="{StaticResource BlueButton}"
                            Command="{Binding CapNhatCommand}" Margin="5,0,5,0"/>
                    <Button Grid.Column="5" Content="Thoát"
                            Style="{StaticResource BlueButton}"
                            Command="{Binding ThoatCommand}" Margin="5,0,0,0"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
