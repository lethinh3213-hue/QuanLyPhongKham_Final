<Window x:Class="QuanLyPhongKham.Views.TimPhieuKhamBenhDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tìm phiếu khám bệnh"
        Height="460" Width="680"
        WindowStartupLocation="CenterOwner"
        Background="White"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="BlueButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" Margin="12,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Margin="10">
        <Grid Margin="20,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <TextBlock Grid.Row="0" Text="Tìm phiếu khám bệnh"
                       FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <!-- Ô tìm kiếm -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Từ khóa (Mã phiếu / Họ tên):"
                           Foreground="#374151" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtTuKhoa" Width="320" Height="32"
                         VerticalContentAlignment="Center" Padding="8,0"
                         TextChanged="txtTuKhoa_TextChanged"/>
            </StackPanel>

            <!-- Bảng kết quả -->
            <DataGrid x:Name="dgPhieu" Grid.Row="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      BorderBrush="#D1D5DB"
                      BorderThickness="1"
                      GridLinesVisibility="All"
                      RowHeaderWidth="0"
                      MouseDoubleClick="dgPhieu_MouseDoubleClick"
                      Margin="0,0,0,12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã phiếu"
                                        Binding="{Binding MaPhieuKhamBenh}" Width="90"/>
                    <DataGridTextColumn Header="Họ tên bệnh nhân"
                                        Binding="{Binding HoTenBenhNhan}" Width="*"/>
                    <DataGridTextColumn Header="Ngày khám"
                                        Binding="{Binding NgayKham, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTextColumn Header="Loại phòng khám"
                                        Binding="{Binding TenLoaiPhongKham}" Width="140"/>
                    <DataGridTextColumn Header="Loại bệnh"
                                        Binding="{Binding TenLoaiBenh}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Nút -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Chọn" Style="{StaticResource BlueButton}"
                        MinWidth="100" Margin="0,0,10,0" Click="btnChon_Click"/>
                <Button Content="Đóng" Style="{StaticResource BlueButton}"
                        MinWidth="100" Click="btnDong_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
