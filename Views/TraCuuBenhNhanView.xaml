<Window x:Class="QuanLyPhongKham.Views.TraCuuBenhNhanView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Tra cứu bệnh nhân"
        Height="680" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Danh sách Giới tính tĩnh cho ComboBox -->
        <x:Array x:Key="DanhSachGioiTinh" Type="sys:String">
            <sys:String>Tất cả</sys:String>
            <sys:String>Nam</sys:String>
            <sys:String>Nữ</sys:String>
        </x:Array>

        <!-- Style nút màu xanh -->
        <Style x:Key="BlueButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label nhỏ màu xám cho tiêu đề trường -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Label "từ" / "đến" màu đỏ -->
        <Style x:Key="RangeLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,4,0"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===================== HEADER ===================== -->
            <Border Grid.Row="0"
                    BorderBrush="#E5E7EB"
                    BorderThickness="0,0,0,1"
                    Padding="20,15">
                <Grid>
                    <TextBlock Text="Tra cứu bệnh nhân"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="16"
                            Foreground="#6B7280"
                            Cursor="Hand"
                            Command="{Binding ThoatCommand}"/>
                </Grid>
            </Border>

            <!-- ===================== NỘI DUNG ===================== -->
            <Grid Grid.Row="1" Margin="20,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0: Filter row 1 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 1: Filter row 2 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 2: Filter row 3 (range) -->
                    <RowDefinition Height="Auto"/>
                    <!-- 3: Filter row 4 (range) -->
                    <RowDefinition Height="*"/>
                    <!-- 4: DataGrid -->
                    <RowDefinition Height="Auto"/>
                    <!-- 5: Buttons -->
                </Grid.RowDefinitions>

                <!-- =========== HÀNG 1: Mã BN | Họ tên | Loại PK | Loại bệnh | Triệu chứng =========== -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Mã bệnh nhân" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding MaBenhNhanFilter, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,5,0">
                        <TextBlock Text="Họ tên bệnh nhân" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding HoTenFilter, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5,0,5,0">
                        <TextBlock Text="Loại phòng khám" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Height="32"
                                  ItemsSource="{Binding DanhSachLoaiPhongKham}"
                                  SelectedItem="{Binding LoaiPhongKhamDuocChon}"
                                  DisplayMemberPath="TenLoaiPhongKham"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="5,0,5,0">
                        <TextBlock Text="Loại bệnh" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Height="32"
                                  ItemsSource="{Binding DanhSachLoaiBenh}"
                                  SelectedItem="{Binding LoaiBenhDuocChon}"
                                  DisplayMemberPath="TenLoaiBenh"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="5,0,0,0">
                        <TextBlock Text="Triệu chứng" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding TrieuChungFilter, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- =========== HÀNG 2: Giới tính | Loại thuốc | Đơn vị thuốc | Cách dùng | (trống) =========== -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Giới tính" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Height="32"
                                  ItemsSource="{StaticResource DanhSachGioiTinh}"
                                  SelectedItem="{Binding GioiTinhDuocChon}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,5,0">
                        <TextBlock Text="Loại thuốc" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Height="32"
                                  ItemsSource="{Binding DanhSachLoaiThuoc}"
                                  SelectedItem="{Binding LoaiThuocDuocChon}"
                                  DisplayMemberPath="TenLoaiThuoc"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5,0,5,0">
                        <TextBlock Text="Đơn vị thuốc" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Height="32"
                                  ItemsSource="{Binding DanhSachDonViTinh}"
                                  SelectedItem="{Binding DonViTinhDuocChon}"
                                  DisplayMemberPath="TenDonViTinh"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="5,0,5,0">
                        <TextBlock Text="Cách dùng" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Height="32"
                                  ItemsSource="{Binding DanhSachCachDung}"
                                  SelectedItem="{Binding CachDungDuocChon}"
                                  DisplayMemberPath="TenCachDung"/>
                    </StackPanel>

                    <!-- Cột 4 để trống cho cân với hàng 1 -->
                </Grid>

                <!-- =========== HÀNG 3: Ngày khám từ-đến || Năm sinh từ-đến =========== -->
                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ngày khám -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                        <TextBlock Text="Ngày khám" Foreground="#374151" FontSize="12"
                                   VerticalAlignment="Center" Width="90"/>
                        <TextBlock Text="Từ" Style="{StaticResource RangeLabel}" Margin="0,0,4,0"/>
                        <DatePicker Width="130" Height="32"
                                    SelectedDate="{Binding NgayKhamTu}"/>
                        <TextBlock Text="Đến" Style="{StaticResource RangeLabel}"/>
                        <DatePicker Width="130" Height="32"
                                    SelectedDate="{Binding NgayKhamDen}"/>
                    </StackPanel>

                    <!-- Năm sinh -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                        <TextBlock Text="Năm sinh" Foreground="#374151" FontSize="12"
                                   VerticalAlignment="Center" Width="90"/>
                        <TextBlock Text="Từ" Style="{StaticResource RangeLabel}" Margin="0,0,4,0"/>
                        <TextBox Width="100" Style="{StaticResource InputBox}"
                                 Text="{Binding NamSinhTuStr, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Đến" Style="{StaticResource RangeLabel}"/>
                        <TextBox Width="100" Style="{StaticResource InputBox}"
                                 Text="{Binding NamSinhDenStr, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- =========== HÀNG 4: Số lượng thuốc kê =========== -->
                <Grid Grid.Row="3" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Số lượng thuốc kê -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                        <TextBlock Text="Số lượng thuốc kê" Foreground="#374151" FontSize="12"
                                   VerticalAlignment="Center" Width="120"/>
                        <TextBlock Text="Từ" Style="{StaticResource RangeLabel}" Margin="0,0,4,0"/>
                        <TextBox Width="100" Style="{StaticResource InputBox}"
                                 Text="{Binding SoLuongKeTuStr, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Đến" Style="{StaticResource RangeLabel}"/>
                        <TextBox Width="100" Style="{StaticResource InputBox}"
                                 Text="{Binding SoLuongKeDenStr, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- =========== DATAGRID KẾT QUẢ =========== -->
                <DataGrid Grid.Row="4"
                          ItemsSource="{Binding DanhSachKetQua}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          BorderBrush="#D1D5DB"
                          BorderThickness="1"
                          GridLinesVisibility="All"
                          RowHeaderWidth="0"
                          Margin="0,0,0,15">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT"
                                            Binding="{Binding STT}"
                                            Width="50"/>
                        <DataGridTextColumn Header="Họ tên"
                                            Binding="{Binding HoTen}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Ngày khám"
                                            Binding="{Binding NgayKham, StringFormat=dd/MM/yyyy}"
                                            Width="120"/>
                        <DataGridTextColumn Header="Năm sinh"
                                            Binding="{Binding NamSinh}"
                                            Width="90"/>
                        <DataGridTextColumn Header="Loại phòng khám"
                                            Binding="{Binding TenLoaiPhongKham}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Loại bệnh"
                                            Binding="{Binding TenLoaiBenh}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Triệu chứng"
                                            Binding="{Binding TrieuChung}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- =========== HÀNG NÚT BẤM =========== -->
                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Tra cứu bệnh nhân"
                            Style="{StaticResource BlueButton}"
                            Width="160"
                            Command="{Binding TraCuuCommand}"/>

                    <Button Grid.Column="2" Content="Thoát"
                            Style="{StaticResource BlueButton}"
                            Width="120"
                            Command="{Binding ThoatCommand}"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>