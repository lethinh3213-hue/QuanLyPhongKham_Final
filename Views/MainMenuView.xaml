<Window x:Class="QuanLyPhongKham.Views.MainMenuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý Phòng khám"
        Height="729" Width="480"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Nút menu lớn -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Nút bị disable thì xám đi -->
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#D1D5DB"/>
                    <Setter Property="Foreground" Value="#6B7280"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Margin="10">
        <Grid Margin="0,0,0,-19">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="#1D4ED8" CornerRadius="8,8,0,0" Padding="20,18">
                <StackPanel>
                    <TextBlock Text="PHÒNG KHÁM"
                               Foreground="White" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Hệ thống Quản lý Phòng khám"
                               Foreground="#BFDBFE" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- MENU -->
            <StackPanel Grid.Row="1" Margin="28,28,28,20">
                <Button Content="Tiếp nhận bệnh nhân"
                        Style="{StaticResource MenuButton}"
                        Click="TiepNhan_Click"/>
                <Button Content="Lập phiếu khám bệnh"
                        Style="{StaticResource MenuButton}"
                        Click="LapPhieu_Click"/>
                <Button Content="Tra cứu bệnh nhân"
                        Style="{StaticResource MenuButton}"
                        Click="TraCuu_Click"/>
                <Button Content="Lập hóa đơn thanh toán"
                        Style="{StaticResource MenuButton}"
                        Click="LapHoaDon_Click"/>
                <Button Content="Lập báo cáo hóa đơn theo tháng"
                        Style="{StaticResource MenuButton}"
                        Click="BaoCaoHoaDon_Click"/>
                <Button Content="Lập báo cáo sử dụng thuốc theo tháng"
                        Style="{StaticResource MenuButton}"
                        Click="BaoCaoThuoc_Click"/>

                <Button Content="Thay đổi quy định"
                        Style="{StaticResource MenuButton}"
                        Click="ThayDoiQuyDinh_Click"/>

                <Button Content="Thoát"
                        Style="{StaticResource MenuButton}"
                        Background="#6B7280"
                        Height="44" FontSize="14"
                        Margin="0,6,0,0"
                        Click="Thoat_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
